{
  "name": "better-review",
  "version": "0.1.0",
  "description": "Local PR review helper combining claude CLI + gh CLI with a browser UI.",
  "type": "module",
  "bin": { "better-review": "dist/cli/index.js" },
  "files": ["dist", "prompts/builtin.md", "README.md"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.server.json && node -e \"import('node:fs').then(fs=>fs.cpSync('src/server/db/migrations','dist/server/db/migrations',{recursive:true}))\"",
    "build:web": "vite build",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier -w ."
  },
  "dependencies": {
    "@hono/node-server": "^1.13.5",
    "better-sqlite3": "^11.5.0",
    "chokidar": "^4.0.1",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "hono": "^4.6.10",
    "nanoid": "^5.0.9",
    "open": "^10.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
