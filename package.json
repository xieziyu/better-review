{
  "name": "better-review",
  "version": "0.1.0",
  "description": "Local PR review helper combining claude CLI + gh CLI with a browser UI.",
  "type": "module",
  "bin": { "better-review": "dist/cli/index.js" },
  "files": ["dist", "prompts/builtin.md", "README.md"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "npm run build:server && npm run build:web && node scripts/copy-assets.mjs",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:web": "vitest run --config vitest.web.config.ts",
    "e2e": "playwright test",
    "lint": "eslint .",
    "format": "prettier -w ."
  },
  "dependencies": {
    "@hono/node-server": "^1.13.5",
    "@tanstack/react-query": "^5.59.0",
    "better-sqlite3": "^11.5.0",
    "chokidar": "^4.0.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "hono": "^4.6.10",
    "lucide-react": "^0.453.0",
    "nanoid": "^5.0.9",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "react-diff-view": "^3.2.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.27.0",
    "rehype-highlight": "^7.0.0",
    "shiki": "^1.22.2",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^8.57.1",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
