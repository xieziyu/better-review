{
  "name": "@xieziyu/better-review",
  "version": "0.5.0",
  "description": "Local PR review helper combining a review-agent CLI (codex / claude / pi) and gh CLI with a browser UI.",
  "keywords": [
    "claude",
    "cli",
    "code-review",
    "codex",
    "github",
    "local-first",
    "pr-review"
  ],
  "homepage": "https://github.com/xieziyu/better-review#readme",
  "bugs": {
    "url": "https://github.com/xieziyu/better-review/issues"
  },
  "license": "GPL-3.0-or-later",
  "author": "xieziyu <rainnyxzy@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xieziyu/better-review.git"
  },
  "bin": {
    "better-review": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:web && node scripts/copy-assets.mjs",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:web": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:web": "vitest run --config vitest.web.config.ts",
    "e2e": "playwright test",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepack": "npm run build",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@hono/node-server": "^1.13.5",
    "@tanstack/react-query": "^5.59.0",
    "better-sqlite3": "^11.5.0",
    "chokidar": "^4.0.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "hono": "^4.6.10",
    "i18next": "^26.0.10",
    "lucide-react": "^0.453.0",
    "nanoid": "^5.0.9",
    "open": "^10.1.0",
    "picomatch": "^4.0.4",
    "react": "^18.3.1",
    "react-diff-view": "^3.2.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.7",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.27.0",
    "shiki": "^1.22.2",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "postcss": "^8.4.47",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,cjs,ts,tsx,mts,cts,json,jsonc}": "oxfmt --write"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
