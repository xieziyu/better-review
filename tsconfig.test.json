{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/web/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": ["tests/**/*", "src/**/*"]
}
